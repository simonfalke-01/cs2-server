# Control-plane configuration (orchestrator + Discord bot).
# Copy to controlplane.env and fill in. controlplane.env is gitignored.

# --- Orchestrator API ----------------------------------------------------
CS2C_API_ADDR=:8080
CS2C_STATE_PATH=/data/cs2-server.db

# Docker image used for game servers (build with: make image).
CS2C_IMAGE=cs2-server/cs2:latest

# Host paths. When running the orchestrator in a container these must match the
# host side of the volume mounts in controlplane.compose.yml, because the
# orchestrator passes HOST paths to the Docker API for game-container binds.
CS2C_DATA_ROOT=/data/instances
CS2C_PLUGINS_DIR=

# IP advertised to players in the connect string.
CS2C_PUBLIC_IP=127.0.0.1

# UDP/TCP port window for on-demand servers (game + RCON ports are drawn here).
CS2C_GAME_PORT_MIN=27015
CS2C_GAME_PORT_MAX=27115

# Defaults for new servers.
CS2C_DEFAULT_MAP=de_inferno
CS2C_DEFAULT_MAXPLAYERS=10

# Fallback GSLT used when a public server is requested without an explicit one.
# Get one at https://steamcommunity.com/dev/managegameservers
CS2C_DEFAULT_GSLT=
# Optional, for future stats/workshop features.
CS2C_STEAM_API_KEY=

# Stop servers with 0 players after N minutes (0 disables the reaper).
CS2C_IDLE_SHUTDOWN_MINUTES=30
CS2C_MAX_SERVERS_PER_USER=2

# --- Discord bot ---------------------------------------------------------
DISCORD_TOKEN=
DISCORD_APP_ID=
# Optional: a guild id makes slash commands appear instantly (good for dev).
DISCORD_GUILD_ID=

# Base URL the bot uses to reach the orchestrator API.
# In the compose network this is the service name; on the host use 127.0.0.1.
CS2C_ORCHESTRATOR_URL=http://orchestrator:8080
