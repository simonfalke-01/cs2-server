# Example environment for a standalone CS2 game-server container.
# Copy to cs2.env and fill in. cs2.env is gitignored.

# --- Identity / access ---------------------------------------------------
CS2_SERVERNAME=cs2-server dev box
CS2_RCONPW=changeme-rcon
# Optional server join password (leave empty for open).
CS2_PW=

# Public servers require a Game Server Login Token (GSLT):
#   https://steamcommunity.com/dev/managegameservers
# Leave SRCDS_TOKEN empty AND set CS2_LAN=1 for a private/LAN-only server.
SRCDS_TOKEN=
CS2_LAN=1

# --- Gameplay ------------------------------------------------------------
CS2_MAXPLAYERS=10
CS2_STARTMAP=de_inferno
CS2_MAPGROUP=mg_active
# Default competitive: game_type 0 / game_mode 1. See Valve dedicated server docs.
CS2_GAMETYPE=0
CS2_GAMEMODE=1

# Add a few bots so a round actually starts for testing the plugin.
CS2_BOT_QUOTA=4
CS2_BOT_DIFFICULTY=1

# --- Misc ----------------------------------------------------------------
# Required for CounterStrikeSharp commands like css_hello to be usable.
CS2_CHEATS=0
# 0=none, 1=steamcmd, 2=cs2, 3=all
DEBUG=2
