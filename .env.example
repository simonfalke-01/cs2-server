# Copy to .env (gitignored) and adjust. `docker compose up -d --build` reads it.
# Everything runs in compose; there are no host paths to configure.

# Public IP players connect to (used in the /create connect string).
CS2C_PUBLIC_IP=127.0.0.1

# Host port the orchestrator API is published on.
CS2C_API_PORT=18080

# Shared game files: one seeded game copy shared by all servers (recommended).
# Auto-uses fuse-overlayfs on rootless Docker. Set false to give each server its
# own full game copy.
CS2C_SHARED_GAME_FILES=true

# On-demand server UDP/TCP port window (game + RCON drawn here). Publish/allow
# this range in your firewall.
CS2C_GAME_PORT_MIN=27015
CS2C_GAME_PORT_MAX=27115

# Defaults for new servers.
CS2C_DEFAULT_MAP=de_inferno
# Default game-mode preset when /create is called without mode:
# (competitive | wingman | deathmatch | 1v1).
CS2C_DEFAULT_MODE=competitive
CS2C_DEFAULT_MAXPLAYERS=10
# Fallback GSLT for public servers (https://steamcommunity.com/dev/managegameservers).
CS2C_DEFAULT_GSLT=

# Idle reaper / quota.
CS2C_IDLE_SHUTDOWN_MINUTES=30
CS2C_MAX_SERVERS_PER_USER=2

# --- Discord bot (only needed if you run the `bot` compose profile) ---
DISCORD_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
